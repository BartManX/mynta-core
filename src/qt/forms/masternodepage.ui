          </widget>
         </item>
         <item>
          <widget class="QLabel" name="stepArrow3">
           <property name="text">
            <string>→</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QLabel" name="step4Label">
           <property name="text">
            <string>4️⃣ Complete</string>
           </property>
           <property name="toolTip">
            <string>Step 4: Your masternode registration is broadcast to the network. After confirmation, your masternode goes live!</string>
           </property>
          </widget>
         </item>
         <item>
          <spacer name="stepsSpacer">
